<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN"
            "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

	<!-- add your bean definitions here! -->

    <bean id="dataSource"
          class="org.springframework.jdbc.datasource.SimpleDriverDataSource">
        <property name="driverClass" value="org.hsqldb.jdbcDriver"/>
        <property name="url" value="jdbc:hsqldb:file:database.dat;shutdown=true"/>
        <property name="username" value="sa"/>
        <property name="password" value=""/>
    </bean>

    <bean id="jdbcTemplate"
          class="org.springframework.jdbc.core.JdbcTemplate">
        <constructor-arg ref="dataSource"/>
    </bean>

    <bean id="customerDao"
          class="se.yrgo.dataaccess.CustomerDaoJdbcTemplateImpl"
          init-method="createTables">
        <constructor-arg ref="jdbcTemplate"/>
    </bean>

    <bean id="customerManagementService"
          class="se.yrgo.services.customers.CustomerManagementServiceProductionImpl">
        <property name="customerDao" ref="customerDao" />
    </bean>

    <bean id="customerManagement"
          class="se.yrgo.services.customers.CustomerManagementMockImpl" />

    <bean id="diaryManagement"
          class="se.yrgo.services.diary.DiaryManagementServiceMockImpl" />

    <bean id="callHandling"
          class="se.yrgo.services.calls.CallHandlingServiceImpl">
        <property name="customerService" ref="customerManagementService" />
        <property name="diaryService" ref="diaryManagement" />
    </bean>

</beans>
