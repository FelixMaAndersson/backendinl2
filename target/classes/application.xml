<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN"
            "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

	<!-- add your bean definitions here! -->

    <bean id="customerManagement"
          class="se.yrgo.services.customers.CustomerManagementMockImpl" />

    <bean id="diaryManagement"
          class="se.yrgo.services.diary.DiaryManagementServiceMockImpl" />

    <bean id="callHandling"
          class="se.yrgo.services.calls.CallHandlingServiceImpl">
        <property name="customerService" ref="customerManagement" />
        <property name="diaryService" ref="diaryManagement" />
    </bean>

</beans>
